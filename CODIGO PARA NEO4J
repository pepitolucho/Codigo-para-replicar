// CONSTRAINTS 

CREATE CONSTRAINT org_id IF NOT EXISTS
FOR (o:Organism) REQUIRE o.id IS UNIQUE;

CREATE CONSTRAINT tx_key IF NOT EXISTS
FOR (t:Transcription) REQUIRE t.key IS UNIQUE;

CREATE CONSTRAINT og_id IF NOT EXISTS
FOR (og:OrthologGroup) REQUIRE og.id IS UNIQUE;

// Nodo temporal de mapeo gene->og
CREATE CONSTRAINT genemap_key IF NOT EXISTS
FOR (m:GeneMap) REQUIRE m.key IS UNIQUE;


// CODIGO PARA EL REPOSITORIO DE GITHUB DONDE TENEMOS LOS ARCHIVOS
:param BASE_RAW => 'https://raw.githubusercontent.com/USUARIO/REPO/main';


// CODIGO PARA CREAR LOS 6 NODOS ORGANISMO (ACA SE PUEDEN CREAR CUANTOS SE QUIERA)
UNWIND ['Ecoli','Salmon','Bacsu','Pseudo','Staphi','Myctu'] AS org   // ESTE ES EL NOMBRE QUE LES PUSE YO 
MERGE (:Organism {id: org});

// CARGAR LOS GENEMAP (NODOS TEMPORALES) DESDE LOS TSV ENTREGADOS POR EGGNOG MAPPER
UNWIND [
  // -------- REGULADORES --------
  {org:'Ecoli',  file:'ECOLI_REGULADORES_gene_to_rootOG_clean.tsv'},
  {org:'Salmon', file:'SALMON_REGULADORES_gene_to_rootOG_clean.tsv'},
  {org:'Bacsu',  file:'BACSU_REGULADORES_gene_to_rootOG_clean.tsv'},
  {org:'Pseudo', file:'PSEUDO_REGULADORES_gene_to_rootOG_clean.tsv'},
  {org:'Staphi',  file:'STAPH_REGULADORES_gene_to_rootOG_clean.tsv'},
  {org:'Myctu',  file:'MYCTU_REGULADORES_gene_to_rootOG_clean.tsv'},

  // -------- REGULADOS --------
  {org:'Ecoli',  file:'ECOLI_REGULADOS_gene_to_rootOG_clean.tsv'},
  {org:'Salmon', file:'SALMON_REGULADOS_gene_to_rootOG_clean.tsv'},
  {org:'Bacsu',  file:'BACSU_REGULADOS_gene_to_rootOG_clean.tsv'},
  {org:'Pseudo', file:'PSEUDO_REGULADOS_gene_to_rootOG_clean.tsv'},
  {org:'Staphi',  file:'STAPH_REGULADOS_gene_to_rootOG_clean.tsv'},
  {org:'Myctu',  file:'MYCTU_REGULADOS_gene_to_rootOG_clean.tsv'}
] AS src

LOAD CSV WITH HEADERS FROM ($BASE_RAW + '/' + src.file) AS row
FIELDTERMINATOR '\t'

WITH src, row
WHERE row.gene_id IS NOT NULL AND row.root_og IS NOT NULL AND row.root_og <> ""

MERGE (m:GeneMap {key: src.org + '|' + row.gene_id})
SET m.org = src.org, m.gene_id = row.gene_id, m.root_og = row.root_og;


//CREAR GRUPOS ORTOLOGOS Y LA RELACION HAS_OG
MATCH (m:GeneMap)
MERGE (o:Organism {id: m.org})
MERGE (og:OrthologGroup {id: m.root_og})
MERGE (o)-[:HAS_OG]->(og);

//CARGAR LAS REDES TXT DE 7 COLUMNAS, CREAR LAS TRANSCRIPCIONES Y LINKEAR A LOS GRUPOS ORTOLOGOS
UNWIND [
  {org:'Ecoli',  file:'GCF_000005845.2_E_coli_K12_genomic_extended_network.txt'},
  {org:'Salmon', file:'salmonella.txt'},
  {org:'Bacsu',  file:'bacillus.txt'},
  {org:'Pseudo', file:'pseudo.txt'},
  {org:'Staphi',  file:'estafi.txt'},
  {org:'Myctu',  file:'Myctu.txt'}  //LOS NOMBRES DE LOS ARCHIVOS SON SOLO REFERENCIA 
] AS src

LOAD CSV FROM ($BASE_RAW + '/' + src.file) AS row
FIELDTERMINATOR '\t'

WITH src,
     replace(trim(row[0]),'"','') AS edge_id,
     replace(trim(row[1]),'"','') AS tf_id,
     replace(trim(row[2]),'"','') AS tg_id,
     replace(trim(row[3]),'"','') AS category,
     CASE WHEN size(row) > 4 THEN replace(trim(row[4]),'"','') ELSE null END AS ref_orgs,
     CASE WHEN size(row) > 5 THEN replace(trim(row[5]),'"','') ELSE null END AS ref_ids,
     CASE WHEN size(row) > 6 THEN replace(trim(row[6]),'"','') ELSE null END AS n_orgs
WHERE edge_id <> "" AND tf_id <> "" AND tg_id <> ""

MERGE (o:Organism {id: src.org})

MERGE (t:Transcription {key: src.org + '|' + edge_id})
  ON CREATE SET t.id = edge_id, t.org = src.org
SET t.category = category,
    t.ref_orgs_raw = ref_orgs,
    t.ref_ids_raw  = ref_ids,
    t.n_orgs = CASE WHEN n_orgs IS NULL OR n_orgs = "" OR n_orgs = "NULL"
                    THEN null ELSE toInteger(n_orgs) END,
    // guardamos IDs originales por si acaso
    t.tf_id = tf_id,
    t.tg_id = tg_id

MERGE (o)-[:HAS_TRANSCRIPTION]->(t)

// lookup TF/TG -> OG usando GeneMap
WITH src, t, tf_id, tg_id
MATCH (mTF:GeneMap {key: src.org + '|' + tf_id})
MATCH (mTG:GeneMap {key: src.org + '|' + tg_id})
MERGE (ogTF:OrthologGroup {id: mTF.root_og})
MERGE (ogTG:OrthologGroup {id: mTG.root_og})
MERGE (t)-[:TF_OG]->(ogTF)
MERGE (t)-[:TG_OG]->(ogTG);


//CREAR RELACION HOMOLOGOUS_TO 

MATCH (t:Transcription)
WITH t,
     [x IN split(coalesce(t.ref_orgs_raw,''), ',') | replace(trim(x),'"','')] AS orgs,
     [y IN split(coalesce(t.ref_ids_raw ,''), ',') | replace(trim(y),'"','')] AS ids
WITH t, orgs, ids, range(0, size(orgs)-1) AS idxs
UNWIND idxs AS i
WITH t, orgs[i] AS refOrg, ids[i] AS refId
WHERE refOrg <> '' AND refId <> ''
  AND refOrg <> 'NOT_REFR_ORG'
  AND refId  <> 'NOT_REFR_NUM'
  AND refId  <> 'NULL'
MATCH (t2:Transcription {key: refOrg + '|' + refId})
MERGE (t)-[:HOMOLOGOUS_TO]->(t2);


//CREAR LA RELACION OG_REGULATES_OG
MATCH (o:Organism)-[:HAS_TRANSCRIPTION]->(t:Transcription)
MATCH (t)-[:TF_OG]->(ogTF:OrthologGroup)
MATCH (t)-[:TG_OG]->(ogTG:OrthologGroup)
WITH ogTF, ogTG, o.id AS org,
     count(*) AS n,
     sum(CASE WHEN t.category = 'Known' THEN 1 ELSE 0 END) AS known_n,
     sum(CASE WHEN t.category = 'New'   THEN 1 ELSE 0 END) AS new_n
MERGE (ogTF)-[r:OG_REGULATES_OG {org: org}]->(ogTG)
SET r.n = n, r.known_n = known_n, r.new_n = new_n;


//CODIGO PARA HACER OG(TF)->OG(TG)
MATCH p = (a:OrthologGroup)-[:OG_REGULATES_OG {org:'Ecoli'}]->(b:OrthologGroup)
RETURN p
LIMIT 200;


//CODIGO PARA HACER EL GRAFO ORGANISMO->TRANSCRIPCION->TRANSCRIPCION HOMOLOGA->ORGANISMO DE LA TRANSCRIPCION HOMOLOGA
MATCH p =
  (o:Organism {id:'Ecoli'})-[:HAS_TRANSCRIPTION]->(t:Transcription)
  -[:HOMOLOGOUS_TO]->(t2:Transcription)<-[:HAS_TRANSCRIPTION]-(o2:Organism)
RETURN p
LIMIT 50;

//CODIGO PARA HACER EL GRAFO ORGANISMO->TRANSCRIPCION->OG(TF)->OG(TG) + TRANSCRIPCIONES HOMOLOGAS 
MATCH (o:Organism {id:'Ecoli'})-[r1:HAS_TRANSCRIPTION]->(t:Transcription)
MATCH (t)-[r2:TF_OG]->(ogTF:OrthologGroup)
MATCH (t)-[r3:TG_OG]->(ogTG:OrthologGroup)
OPTIONAL MATCH (t)-[r4:HOMOLOGOUS_TO]->(t2:Transcription)<-[r5:HAS_TRANSCRIPTION]-(o2:Organism)
RETURN o,r1,t,r2,ogTF,r3,ogTG,r4,t2,r5,o2
LIMIT 50;



















